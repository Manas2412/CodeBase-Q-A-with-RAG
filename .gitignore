# ─── Secrets ───────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# NOTE: don't add bare `lib/` or `lib64/` here — those come from Python's
# stock venv .gitignore template and they'd also catch frontend/src/lib/.
# The virtualenv itself is already covered by `.venv/`.
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ─── Test / lint caches ───────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.hypothesis/
coverage.xml
*.cover

# ─── Node / Frontend ──────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
.vite/

# ─── IDE / OS ─────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Docker / data volumes ────────────────────────
postgres-data/
redis-data/
codereview-repos/

# ─── Local clones managed by the review agent ────
/var/lib/codereview/

# ─── Project artifacts ────────────────────────────
*.log
logs/
