# ─── Datastores ─────────────────────────────────────  REQUIRED ──
# Local dev defaults assume the two docker containers documented in
# backend/README.md (codereview-postgres on host port 5434, codereview-redis
# on host port 6380). Replace with real DSNs for staging/prod.
DATABASE_URL=postgresql+asyncpg://codereview:local_dev_only@localhost:5434/codereview
REDIS_URL=redis://localhost:6380/0


# ─── AWS BEDROCK — review LLM + embedder ────────────  REQUIRED ──
# Credentials from the dedicated 'code-review-bot' IAM user (never root).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

LLM_PROVIDER=bedrock
INGESTION_LLM_PROVIDER=bedrock

# Opus 4.x on Bedrock requires an inference profile (us./global./etc).
BEDROCK_LLM_MODEL=us.anthropic.claude-opus-4-6-v1
BEDROCK_LLM_VALIDATION_MODEL=us.anthropic.claude-opus-4-6-v1
# Note: max_tokens is NOT here. It's a constant (MAX_OUTPUT_TOKENS = 16384)
# in app/review/bedrock_client.py. Bedrock bills per actual output, so a
# generous cap is free; it just prevents truncation.

EMBEDDING_PROVIDER=bedrock
BEDROCK_EMBED_MODEL=cohere.embed-multilingual-v3
BEDROCK_EMBED_INPUT_TYPE_DOC=search_document
BEDROCK_EMBED_INPUT_TYPE_QUERY=search_query
EMBED_DIMENSION=1024


# ─── Source platform credentials ────────────────────  REQUIRED ──
# OpenForge (Tuleap) personal access key from a service account.
# Scope: REST + Git repository. Format: tlp.k1.…
OPENFORGE_TOKEN=

# Optional — only if internal GitHub repos are also onboarded.
GITHUB_TOKEN=
