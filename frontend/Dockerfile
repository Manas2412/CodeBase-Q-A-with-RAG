# syntax=docker/dockerfile:1.7
#
# Two-stage build for the codebase review agent frontend.
#
# Stage 1 (builder) : node:20-alpine compiles the Vite SPA into dist/
# Stage 2 (runtime) : nginx:1.27-alpine serves the static files
#
# Caddy (in the server-mode docker-compose) terminates TLS and routes:
#   /         → this frontend container :80
#   /api/*    → backend container :8000

# ── Stage 1: Vite build ───────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Install dependencies first for layer caching.
# We use `npm install` (not `npm ci`) because the lockfile generated by older
# local npm versions can disagree with newer npm in the container over
# platform-conditional transitive deps (@emnapi/* etc.). `npm install` patches
# those without erroring out, while still respecting locked versions where
# they exist. For strict reproducibility, upgrade local npm to match the
# container (`npm install -g npm@latest`) and switch this back to `npm ci`.
COPY package.json package-lock.json ./
RUN npm install --no-audit --no-fund

# Then bring in the source and build
COPY . .
RUN npm run build


# ── Stage 2: nginx serving static files ───────────────────────────────────
FROM nginx:1.27-alpine AS runtime

# Replace the default config with our SPA-aware one
RUN rm /etc/nginx/conf.d/default.conf
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Drop the built dist/ into nginx's docroot
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

# Run nginx in the foreground (Docker convention)
CMD ["nginx", "-g", "daemon off;"]
